# Copy to `.env`. For local SQLite only (no Postgres): USE_SQLITE=1
# For Docker Compose: omit USE_SQLITE (or set to 0).

POSTGRES_DB=gradesync
POSTGRES_USER=gradesync
POSTGRES_PASSWORD=gradesync
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Public URL of the app (password-reset links in welcome emails). With Docker mapping port 80:
SITE_URL=http://localhost

# Email — Docker Compose starts Mailpit and defaults web → SMTP mailpit:1025 (no TLS).
# Open http://localhost:8025 to read dev mail. Do NOT set EMAIL_BACKEND=console if you want Mailpit.
#
# Production / campus SMTP (example):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.edu
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=true
# DEFAULT_FROM_EMAIL=GradeSync <noreply@yourdomain.edu>
